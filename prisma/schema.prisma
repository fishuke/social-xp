// Neon Postgres (via Vercel integration).
// DATABASE_URL is the pooled connection (runtime); DATABASE_URL_UNPOOLED is the
// direct connection Prisma uses for db push / migrations.

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id              String   @id @default(cuid())
  email           String?  @unique // set when the anonymous user creates an account
  emailVerified   DateTime? // set when the verification link is clicked
  passwordHash    String?
  role            String   @default("user") // "user" | "admin" — admin unlocks /admin
  locale          String   @default("en") // UI + content language: "en" | "tr"
  name            String   @default("Alex")
  goal            String?
  pace            String   @default("steady") // chill | steady | beast
  timezone        String? // IANA zone from onboarding/claim; null = server time
  reminderTime    String   @default("19:30")
  isPremium       Boolean  @default(false)
  activeCourseId  Int      @default(1)
  totalXP         Int      @default(0)
  streakCount     Int      @default(0)
  lastGoalMetDate String? // YYYY-MM-DD, local
  repsCompleted   Int      @default(0)
  streakShields   Int      @default(0) // chest drops; auto-consumed to save a missed day (cap 2)
  openedChests    String   @default("[]") // JSON array of opened chest ids, e.g. ["c1","s7"]
  createdAt       DateTime @default(now())

  lessons LessonCompletion[]
  quotes  CollectedQuote[]
  daily   DailyState[]
  pushSubs PushSubscription[]
  coachSessions CoachSession[]
  authTokens AuthToken[]
  subscriptions Subscription[]
}

// ---------- payments (provider-agnostic; adapters live in lib/payments) ----------

// One row per provider subscription. Re-subscribing after expiry creates a new
// provider subscription id, hence a new row; User.isPremium follows whichever
// subscription still grants access (lib/payments/subscriptions.ts).
model Subscription {
  id                     String    @id @default(cuid())
  userId                 String
  provider               String // "lemonsqueezy" | future providers
  providerSubscriptionId String // the provider's own id - webhook lookups + portal calls
  customerId             String? // provider customer id
  status                 String // normalized: trialing|active|past_due|canceled|paused|expired
  plan                   String? // "monthly" | "yearly"
  renewsAt               DateTime?
  endsAt                 DateTime? // set once canceled; access runs until here
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerSubscriptionId])
  @@index([userId])
}

// Every signature-verified webhook payload, verbatim - audit trail plus the
// raw material for the revenue dashboards (docs/ROADMAP.md item 8).
model PaymentEvent {
  id        String   @id @default(cuid())
  provider  String
  eventName String
  payload   Json
  createdAt DateTime @default(now())

  @@index([provider, createdAt])
}

// Single-use, expiring tokens for password reset and email verification.
// Only the sha256 hash is stored; the raw token lives in the emailed link.
model AuthToken {
  tokenHash String   @id
  userId    String
  type      String // "reset" | "verify"
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
}

// Sliding-window rate limiting (login failures, reset requests).
// key example: "login:demo@social.xp"
model AuthThrottle {
  key     String   @id
  count   Int      @default(0)
  resetAt DateTime
}

// One AI-coach rep: a short voice recording analyzed by Gemini (see lib/coach.ts).
model CoachSession {
  id          String   @id @default(cuid())
  userId      String
  date        String // YYYY-MM-DD — daily free-gating + XP cap
  promptText  String
  durationSec Int
  transcript  String
  wpm         Int
  fillerCount Int
  overall     Int // 0–100
  confidence  Int
  clarity     Int
  energy      Int
  pace        Int // 0–100; label lives in feedback JSON
  feedback    Json // {headline, summary, paceLabel, fillerWords, strengths, oneThing, tryNext}
  xpAwarded   Int      @default(0)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
}

// Web-push endpoints (one per browser/device). Populated when a user opts into
// daily reminders; the reminder cron sends to every row for a due user.
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String // client public key (base64url)
  auth      String // client auth secret (base64url)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model LessonCompletion {
  id          String   @id @default(cuid())
  userId      String
  chapterId   Int
  lessonIndex Int // 1-based
  feel        String? // crushed | got-it | shaky
  completedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, chapterId, lessonIndex])
}

model CollectedQuote {
  id      String   @id @default(cuid())
  userId  String
  quoteId String // e.g. "c1-l3"
  savedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, quoteId])
}

// ---------- content (DB-managed lessons & units; seeded from prisma/seed.ts) ----------

model Course {
  id        Int    @id
  title     String
  tagline   String
  sortOrder Int    @default(0)
  units     Unit[]

  translations CourseTranslation[]
}

model Unit {
  id         Int    @id
  courseId   Int
  number     Int // display order within the course
  level      String // CEFR-style: "A1", "A2"…
  levelTitle String // e.g. "Survival Social"
  title      String
  tagline    String
  canDo      String // CEFR can-do statement

  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]
  quotes  Quote[]

  translations UnitTranslation[]

  @@unique([courseId, number])
}

model Lesson {
  id           Int     @id @default(autoincrement())
  unitId       Int
  index        Int // 1-based within the unit
  title        String
  isCheckpoint Boolean @default(false)
  steps        Json // [{type:"concept"|"quiz", ...}] — see LessonStep in lib/content.ts
  challenge    Json // {text, sub}

  unit Unit @relation(fields: [unitId], references: [id], onDelete: Cascade)

  translations LessonTranslation[]

  @@unique([unitId, index])
}

model Quote {
  id          String  @id // "u1-l3"
  unitId      Int
  lessonIndex Int
  text        String
  author      String
  authorNote  String
  rare        Boolean @default(false)

  unit Unit @relation(fields: [unitId], references: [id], onDelete: Cascade)

  translations QuoteTranslation[]

  @@unique([unitId, lessonIndex])
}

// ---------- content translations (per-locale overlay; English lives in the base rows) ----------
// Base Course/Unit/Lesson/Quote rows hold the English (default) content and own
// the ids that user progress keys on. Non-English locales add a row here; the
// catalog (lib/catalog.ts) overlays these on read and falls back to base.

model CourseTranslation {
  courseId Int
  locale   String
  title    String
  tagline  String

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@id([courseId, locale])
}

model UnitTranslation {
  unitId     Int
  locale     String
  levelTitle String
  title      String
  tagline    String
  canDo      String

  unit Unit @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@id([unitId, locale])
}

model LessonTranslation {
  lessonId  Int
  locale    String
  title     String
  steps     Json // same shape as Lesson.steps — validated in lib/catalog.ts
  challenge Json // same shape as Lesson.challenge

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@id([lessonId, locale])
}

model QuoteTranslation {
  quoteId    String
  locale     String
  text       String
  author     String
  authorNote String

  quote Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@id([quoteId, locale])
}

// One row per user per local day; all quest/gating counters reset by keying on date.
model DailyState {
  id               String  @id @default(cuid())
  userId           String
  date             String // YYYY-MM-DD
  lessonsDoneToday Int     @default(0)
  xpEarnedToday    Int     @default(0)
  repDoneToday     Boolean @default(false)
  repPending       Boolean @default(false)
  chestOpened      Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

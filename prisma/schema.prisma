// Neon Postgres (via Vercel integration).
// DATABASE_URL is the pooled connection (runtime); DATABASE_URL_UNPOOLED is the
// direct connection Prisma uses for db push / migrations.

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id              String   @id @default(cuid())
  email           String?  @unique // set when the anonymous user creates an account
  passwordHash    String?
  name            String   @default("Alex")
  goal            String?
  pace            String   @default("steady") // chill | steady | beast
  reminderTime    String   @default("19:30")
  isPremium       Boolean  @default(false)
  activeCourseId  Int      @default(1)
  totalXP         Int      @default(0)
  streakCount     Int      @default(0)
  lastGoalMetDate String? // YYYY-MM-DD, local
  repsCompleted   Int      @default(0)
  streakShields   Int      @default(0) // chest drops; auto-consumed to save a missed day (cap 2)
  openedChests    String   @default("[]") // JSON array of opened chest ids, e.g. ["c1","s7"]
  createdAt       DateTime @default(now())

  lessons LessonCompletion[]
  quotes  CollectedQuote[]
  daily   DailyState[]
}

model LessonCompletion {
  id          String   @id @default(cuid())
  userId      String
  chapterId   Int
  lessonIndex Int // 1-based
  feel        String? // crushed | got-it | shaky
  completedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, chapterId, lessonIndex])
}

model CollectedQuote {
  id      String   @id @default(cuid())
  userId  String
  quoteId String // e.g. "c1-l3"
  savedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, quoteId])
}

// ---------- content (DB-managed lessons & units; seeded from prisma/seed.ts) ----------

model Course {
  id        Int    @id
  title     String
  tagline   String
  sortOrder Int    @default(0)
  units     Unit[]
}

model Unit {
  id         Int    @id
  courseId   Int
  number     Int // display order within the course
  level      String // CEFR-style: "A1", "A2"…
  levelTitle String // e.g. "Survival Social"
  title      String
  tagline    String
  canDo      String // CEFR can-do statement

  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]
  quotes  Quote[]

  @@unique([courseId, number])
}

model Lesson {
  id           Int     @id @default(autoincrement())
  unitId       Int
  index        Int // 1-based within the unit
  title        String
  isCheckpoint Boolean @default(false)
  steps        Json // [{type:"concept"|"quiz", ...}] — see LessonStep in lib/content.ts
  challenge    Json // {text, sub}

  unit Unit @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@unique([unitId, index])
}

model Quote {
  id          String  @id // "u1-l3"
  unitId      Int
  lessonIndex Int
  text        String
  author      String
  authorNote  String
  rare        Boolean @default(false)

  unit Unit @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@unique([unitId, lessonIndex])
}

// One row per user per local day; all quest/gating counters reset by keying on date.
model DailyState {
  id               String  @id @default(cuid())
  userId           String
  date             String // YYYY-MM-DD
  lessonsDoneToday Int     @default(0)
  xpEarnedToday    Int     @default(0)
  repDoneToday     Boolean @default(false)
  repPending       Boolean @default(false)
  chestOpened      Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}
